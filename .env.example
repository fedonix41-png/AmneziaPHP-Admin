# Environment Configuration
APP_ENV=local
APP_NAME="Amnezia VPN Panel"
SESSION_NAME=amnezia_panel_session

# Default locale
DEFAULT_LOCALE=en

# Database Configuration
DB_HOST=db
DB_PORT=5432
DB_DATABASE=amnezia_panel
DB_USERNAME=amnezia
DB_PASSWORD=amnezia
DB_ROOT_PASSWORD=rootpassword

# Admin Account (auto-created on first run)
ADMIN_EMAIL=admin@amnez.ia
ADMIN_PASSWORD=admin123

# API Configuration
# JWT signing secret (>=32 bytes). Auto-generated & persisted here on first run if empty/placeholder.
JWT_SECRET=
# 32-byte base64 key for at-rest encryption of SSH passwords. Auto-generated on first run.
APP_KEY=
# Auth brute-force protection (POST /api/auth/token) — see docs/security.md#rate-limiting
AUTH_RATE_LIMIT=5
AUTH_RATE_WINDOW=60
AUTH_LOCKOUT_BASE=60
API_RATE_LIMIT=100

# VPN Defaults
DEFAULT_VPN_PORT_MIN=30000
DEFAULT_VPN_PORT_MAX=65000
DEFAULT_VPN_SUBNET=10.8.1.0/24
DEFAULT_DNS=1.1.1.1,1.0.0.1

# ─── Telegram Bot ───
# Bot token from @BotFather
BOT_TOKEN=
# Comma-separated admin Telegram IDs (e.g. 111111,222222)
BOT_ADMIN_TELEGRAM_IDS=
# Run mode: false=polling (default), true=webhook (requires BOT_WEBHOOK_URL)
BOT_USE_WEBHOOK=false
BOT_WEBHOOK_URL=
BOT_WEBHOOK_HOST=0.0.0.0
BOT_WEBHOOK_PORT=8080
# Optional secret token to validate webhook requests
BOT_WEBHOOK_SECRET=
# Panel REST API base URL (internal docker network)
PANEL_API_URL=http://web:80
# Persistent admin API token (POST /api/tokens). Used by the bot to act on its own behalf (e.g. AI assist)
PANEL_API_TOKEN=
REQUEST_TIMEOUT=30
# Telegram-bot database (created automatically alongside amnezia_panel)
TG_DB_HOST=db
TG_DB_PORT=5432
TG_DB_NAME=telegram_bot
TG_DB_USER=amnezia
TG_DB_PASSWORD=amnezia

# ─── Proactive Alerting (bot → admins) ───
# Master switch. Requires PANEL_API_TOKEN and BOT_ADMIN_TELEGRAM_IDS to be set.
ALERT_ENABLED=true
# CPU/RAM thresholds and check interval (seconds)
ALERT_CPU_THRESHOLD=90
ALERT_RAM_THRESHOLD=95
ALERT_CPU_INTERVAL=300
# Overlimit check interval (seconds)
ALERT_OVERLIMIT_INTERVAL=900
# Daily expiring-subscriptions report: run at hour (UTC), look-ahead window (days)
ALERT_EXPIRING_HOUR=9
ALERT_EXPIRING_DAYS=1

# ─── Payments (Telegram Invoices) ───
# Payments token от @BotFather (раздел Payments). Пусто → кнопка «💳 Продлить» скрыта.
# Для тестового токена используйте значение с префиксом, которое выдаёт BotFather.
PAYMENT_PROVIDER_TOKEN=
# ISO 4217 (RUB/USD/EUR/…) либо XTR для Telegram Stars.
# Внимание: для XTR (Stars) provider_token НЕ передаётся.
PAYMENT_CURRENCY=RUB
# JSON-массив тарифов: [{"days":30,"price":199,"label":"1 месяц"}, …]
# price — в целых единицах валюты (рубли/доллары); для XTR — количество Stars.
# Пусто → используются тарифы по умолчанию (1/3/6/12 мес).
PAYMENT_TARIFFS=

# ─── Audit logging (деструктивные действия: блокировки/удаления/сброс ключа) ───
# Мастер-переключатель (false → аудит не пишется и не рассылается).
AUDIT_ENABLED=true
# Отдельный файл для аудита. Пусто → записи идут в общий поток stdout (видны в docker logs).
# По умолчанию пишется в volume /app/logs/audit.log (см. docker-compose.yml → volumes:logs).
# При задании другого пути каталог должен быть доступен для записи.
AUDIT_LOG_FILE=/app/logs/audit.log
# Дублировать деструктивные действия рассылкой админам (требует BOT_ADMIN_TELEGRAM_IDS).
AUDIT_NOTIFY_ADMINS=true

