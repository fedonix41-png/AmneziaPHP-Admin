{% extends "layout.twig" %}

{% block title %}{{ t('auth.register') }} - {{ app_name }}{% endblock %}

{% block styles %}
<style>
    .auth-bg {
        background: radial-gradient(circle at 10% 20%, rgba(99, 102, 241, 0.15) 0%, transparent 45%),
                    radial-gradient(circle at 90% 80%, rgba(168, 85, 247, 0.15) 0%, transparent 45%),
                    linear-gradient(135deg, #090d16 0%, #11102b 100%);
    }
    .glass-card {
        background: rgba(17, 24, 39, 0.6);
        backdrop-filter: blur(20px);
        -webkit-backdrop-filter: blur(20px);
        border: 1px solid rgba(255, 255, 255, 0.06);
    }
    .input-glass {
        background: rgba(17, 24, 39, 0.4);
        border: 1px solid rgba(255, 255, 255, 0.08);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .input-glass:focus {
        border-color: rgba(168, 85, 247, 0.6);
        background: rgba(17, 24, 39, 0.6);
        box-shadow: 0 0 15px rgba(168, 85, 247, 0.2);
    }
    .btn-glow {
        position: relative;
        overflow: hidden;
        transition: all 0.3s ease;
    }
    .btn-glow::after {
        content: '';
        position: absolute;
        top: 0;
        left: -50%;
        width: 200%;
        height: 100%;
        background: linear-gradient(
            to right,
            rgba(255, 255, 255, 0) 0%,
            rgba(255, 255, 255, 0.08) 30%,
            rgba(255, 255, 255, 0.15) 50%,
            rgba(255, 255, 255, 0.08) 70%,
            rgba(255, 255, 255, 0) 100%
        );
        transform: skewX(-25deg);
        transition: 0.75s;
        opacity: 0;
    }
    .btn-glow:hover::after {
        left: 125%;
        opacity: 1;
    }
</style>
{% endblock %}

{% block content %}
<div class="min-h-screen flex items-center justify-center auth-bg py-12 px-4 sm:px-6 lg:px-8">
    <div class="max-w-md w-full">
        <div class="text-center">
            <div class="flex items-center justify-center h-20 w-20 rounded-full bg-gradient-to-tr from-purple-600/20 to-indigo-600/20 border border-purple-500/20 shadow-lg shadow-purple-500/10 mx-auto transition-transform duration-500 hover:scale-105">
                <i class="fas fa-user-plus text-transparent bg-clip-text bg-gradient-to-r from-purple-400 to-indigo-400 text-4xl"></i>
            </div>
            <h2 class="mt-6 text-center text-4xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-white via-slate-100 to-slate-300 tracking-tight">
                {{ t('auth.register') }}
            </h2>
            <p class="mt-2 text-center text-sm text-slate-400 font-light">
                Create an account to manage your VPN servers
            </p>
        </div>
        
        <div class="glass-card rounded-3xl shadow-2xl shadow-black/40 p-8 sm:p-10 mt-8 border border-white/5">
            {% if error %}
            <div class="mb-6 bg-red-500/10 border border-red-500/20 text-red-300 px-4 py-3 rounded-2xl flex items-center gap-2 text-sm" role="alert">
                <i class="fas fa-exclamation-circle text-red-400 flex-shrink-0"></i>
                <span>{{ error }}</span>
            </div>
            {% endif %}

            <form class="space-y-5" method="POST" action="/register">
                <div>
                    <label for="name" class="block text-xs font-semibold text-slate-300 uppercase tracking-wider pl-1">
                        {{ t('auth.name') }}
                    </label>
                    <div class="mt-1.5 relative">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-400">
                            <i class="fas fa-user text-sm"></i>
                        </div>
                        <input id="name" name="name" type="text" required
                               class="appearance-none block w-full pl-11 pr-4 py-3.5 rounded-2xl text-white placeholder-slate-500 text-sm input-glass focus:outline-none"
                               placeholder="Admin">
                    </div>
                </div>

                <div>
                    <label for="email" class="block text-xs font-semibold text-slate-300 uppercase tracking-wider pl-1">
                        {{ t('auth.email') }}
                    </label>
                    <div class="mt-1.5 relative">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-400">
                            <i class="fas fa-envelope text-sm"></i>
                        </div>
                        <input id="email" name="email" type="email" required
                               class="appearance-none block w-full pl-11 pr-4 py-3.5 rounded-2xl text-white placeholder-slate-500 text-sm input-glass focus:outline-none"
                               placeholder="admin@amnez.ia">
                    </div>
                </div>

                <div>
                    <label for="password" class="block text-xs font-semibold text-slate-300 uppercase tracking-wider pl-1">
                        {{ t('auth.password') }}
                    </label>
                    <div class="mt-1.5 relative">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none text-slate-400">
                            <i class="fas fa-lock text-sm"></i>
                        </div>
                        <input id="password" name="password" type="password" required
                               class="appearance-none block w-full pl-11 pr-4 py-3.5 rounded-2xl text-white placeholder-slate-500 text-sm input-glass focus:outline-none"
                               placeholder="••••••••">
                    </div>
                    <p class="mt-1.5 text-xs text-slate-500 pl-1 font-light">Must be at least 6 characters</p>
                </div>

                <div class="pt-2">
                    <button type="submit"
                            class="w-full py-3.5 px-4 bg-gradient-to-r from-purple-600 to-indigo-600 hover:from-purple-500 hover:to-indigo-500 text-white font-semibold rounded-2xl shadow-lg shadow-purple-500/20 btn-glow focus:outline-none focus:ring-2 focus:ring-purple-500 focus:ring-offset-2 focus:ring-offset-slate-900 active:scale-[0.98] transition-all duration-150 flex justify-center items-center gap-2">
                        <i class="fas fa-user-plus text-sm"></i>
                        {{ t('auth.register') }}
                    </button>
                </div>
            </form>

            <div class="text-center text-sm text-slate-400 mt-6 pt-6 border-t border-white/5">
                {% if current_language == 'ru' %}
                    Уже есть аккаунт? <a href="/login" class="text-purple-400 hover:text-purple-300 font-semibold hover:underline">Войти</a>
                {% elseif current_language == 'zh' %}
                    已有账号？ <a href="/login" class="text-purple-400 hover:text-purple-300 font-semibold hover:underline">登录</a>
                {% elseif current_language == 'es' %}
                    ¿Ya tienes una cuenta? <a href="/login" class="text-purple-400 hover:text-purple-300 font-semibold hover:underline">Iniciar sesión</a>
                {% elseif current_language == 'de' %}
                    Bereits ein Konto? <a href="/login" class="text-purple-400 hover:text-purple-300 font-semibold hover:underline">Anmelden</a>
                {% elseif current_language == 'fr' %}
                    Vous avez déjà un compte ? <a href="/login" class="text-purple-400 hover:text-purple-300 font-semibold hover:underline">Se connecter</a>
                {% else %}
                    Already have an account? <a href="/login" class="text-purple-400 hover:text-purple-300 font-semibold hover:underline">Sign in</a>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
